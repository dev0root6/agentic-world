<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Agent World</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323:wght@400&display=swap" rel="stylesheet"/>
<style>
:root {
  --bg:#0d0d0d; --panel:#111318; --border:#2a2d35; --border2:#3a3d45;
  --text:#e8eaf0; --muted:#5a5d6a;
  --accent:#7fff6b; --accent2:#6bbaff;
  --danger:#ff5f5f; --warn:#ffd56b; --purple:#c47fff;
  --pixel:'Press Start 2P',monospace; --vt:'VT323',monospace;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--vt);font-size:18px;overflow:hidden;height:100vh;width:100vw;}
canvas{image-rendering:pixelated;image-rendering:crisp-edges;display:block;}

.screen{position:fixed;inset:0;display:none;z-index:10;}
.screen.active{display:flex;}

/* LOGIN */
#loginScreen{align-items:center;justify-content:center;flex-direction:column;
  background:radial-gradient(ellipse at center,#0d1a0d 0%,#0d0d0d 70%);}
.scanlines{position:fixed;inset:0;pointer-events:none;z-index:1;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,255,0,0.012) 2px,rgba(0,255,0,0.012) 4px);}
.login-box{position:relative;z-index:2;border:2px solid var(--accent);background:#080f08;
  padding:40px 48px;max-width:440px;width:100%;
  box-shadow:0 0 40px rgba(127,255,107,0.15),inset 0 0 40px rgba(0,0,0,0.5);}
.login-title{font-family:var(--pixel);font-size:11px;color:var(--accent);text-align:center;
  margin-bottom:6px;text-shadow:0 0 20px rgba(127,255,107,0.8);line-height:1.8;letter-spacing:1px;}
.login-sub{font-size:16px;color:var(--muted);text-align:center;margin-bottom:32px;}
.login-field{margin-bottom:18px;}
.login-label{font-family:var(--pixel);font-size:7px;color:var(--muted);display:block;margin-bottom:8px;letter-spacing:2px;}
.login-input{width:100%;background:#0a120a;border:1px solid #2a3d2a;color:var(--accent);
  font-family:var(--vt);font-size:20px;padding:10px 14px;outline:none;transition:border-color 0.2s;caret-color:var(--accent);}
.login-input:focus{border-color:var(--accent);box-shadow:0 0 12px rgba(127,255,107,0.2);}
.login-btn{width:100%;background:var(--accent);border:none;color:#050f05;
  font-family:var(--pixel);font-size:9px;padding:14px;cursor:pointer;margin-top:8px;
  transition:all 0.15s;letter-spacing:1px;}
.login-btn:hover{background:#a0ffb0;box-shadow:0 0 20px rgba(127,255,107,0.4);}
.login-btn:disabled{opacity:0.5;cursor:not-allowed;}
.login-error{color:var(--danger);font-family:var(--pixel);font-size:7px;text-align:center;margin-top:12px;display:none;}
.blink{animation:blink 1s step-end infinite;}
@keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}

/* WORLD */
#worldScreen{flex-direction:row;}
.world-wrap{flex:1;overflow:auto;position:relative;background:#050505;
  scrollbar-width:thin;scrollbar-color:var(--border) transparent;}

/* SIDE PANEL */
.side{width:290px;flex-shrink:0;background:var(--panel);border-left:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;}
.side-head{padding:12px 14px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;}
.side-logo{font-family:var(--pixel);font-size:8px;color:var(--accent);
  text-shadow:0 0 10px rgba(127,255,107,0.4);}
.side-tick{font-size:14px;color:var(--muted);}
.tick-wrap{padding:10px 12px;border-bottom:1px solid var(--border);}
.tick-btn{width:100%;background:var(--accent);border:none;color:#050f05;
  font-family:var(--pixel);font-size:7px;padding:9px;cursor:pointer;
  transition:all 0.15s;display:flex;align-items:center;justify-content:center;gap:8px;}
.tick-btn:hover:not(:disabled){background:#a0ffb0;box-shadow:0 0 14px rgba(127,255,107,0.3);}
.tick-btn:disabled{opacity:0.4;cursor:not-allowed;}

.crisis-box{margin:10px 12px;background:#1a0a0a;border:1px solid rgba(255,95,95,0.25);padding:10px;}
.crisis-lbl{font-family:var(--pixel);font-size:6px;color:var(--danger);margin-bottom:6px;letter-spacing:2px;}
.crisis-txt{font-size:14px;color:#ffb0b0;line-height:1.4;}
.crisis-btns{display:flex;gap:6px;margin-top:8px;}
.btn-sm{background:none;border:1px solid;font-family:var(--pixel);font-size:6px;padding:5px 8px;cursor:pointer;transition:all 0.15s;}
.bc{border-color:rgba(255,95,95,0.4);color:var(--danger);}  .bc:hover{background:rgba(255,95,95,0.1);}
.bp{border-color:rgba(196,127,255,0.4);color:var(--purple);} .bp:hover{background:rgba(196,127,255,0.1);}

.lb-sect{flex:1;overflow-y:auto;padding:10px 12px;}
.sect-lbl{font-family:var(--pixel);font-size:6px;color:var(--muted);letter-spacing:2px;margin-bottom:8px;}
.lb-list{display:flex;flex-direction:column;gap:5px;}
.lb-row{display:flex;align-items:center;gap:7px;padding:7px 9px;
  background:#0d0d0d;border:1px solid var(--border);cursor:pointer;transition:border-color 0.15s;}
.lb-row:hover{border-color:var(--border2);}
.lb-num{font-family:var(--pixel);font-size:7px;width:16px;text-align:center;color:var(--muted);}
.lb-num.g{color:#ffd700;}.lb-num.s{color:#c0c0c0;}.lb-num.b{color:#cd7f32;}
.lb-av{font-size:18px;} .lb-info{flex:1;min-width:0;}
.lb-name{font-size:15px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.lb-skill{font-size:12px;color:var(--muted);}
.lb-pts{font-family:var(--pixel);font-size:7px;color:var(--warn);}

.feed-sect{border-top:1px solid var(--border);max-height:200px;overflow-y:auto;}
.feed-head{padding:8px 12px;border-bottom:1px solid var(--border);}
.feed-item{padding:8px 12px;border-bottom:1px solid var(--border);animation:fIn 0.3s ease;}
@keyframes fIn{from{opacity:0;transform:translateY(-3px);}to{opacity:1;transform:translateY(0);}}
.feed-ag{font-size:14px;margin-bottom:2px;display:flex;justify-content:space-between;}
.feed-ac{font-size:12px;color:var(--muted);}

/* ADMIN */
#adminScreen{flex-direction:column;overflow:auto;
  background:radial-gradient(ellipse at top,#0d0a1a 0%,#0d0d0d 60%);}
.adm-wrap{max-width:860px;margin:0 auto;padding:28px 20px;width:100%;}
.adm-head{display:flex;align-items:center;justify-content:space-between;
  margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid var(--border);}
.adm-title{font-family:var(--pixel);font-size:9px;color:var(--purple);
  text-shadow:0 0 14px rgba(196,127,255,0.4);}
.adm-back{background:none;border:1px solid var(--border2);color:var(--muted);
  font-family:var(--pixel);font-size:6px;padding:7px 12px;cursor:pointer;transition:all 0.15s;}
.adm-back:hover{color:var(--text);border-color:var(--text);}
.adm-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px;}
.adm-stat{background:#111;border:1px solid var(--border);padding:14px;}
.adm-val{font-family:var(--pixel);font-size:14px;color:var(--purple);margin-bottom:5px;}
.adm-lbl2{font-size:13px;color:var(--muted);}
.adm-acts{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;}
.adm-btn{background:none;border:1px solid;font-family:var(--pixel);font-size:6px;
  padding:8px 12px;cursor:pointer;transition:all 0.15s;}
.ad{border-color:rgba(255,95,95,0.5);color:var(--danger);}   .ad:hover{background:rgba(255,95,95,0.1);}
.aw{border-color:rgba(255,213,107,0.5);color:var(--warn);}   .aw:hover{background:rgba(255,213,107,0.1);}
.ap{border-color:rgba(196,127,255,0.5);color:var(--purple);} .ap:hover{background:rgba(196,127,255,0.1);}
.ag{border-color:rgba(127,255,107,0.5);color:var(--accent);} .ag:hover{background:rgba(127,255,107,0.1);}
.adm-lbl{font-family:var(--pixel);font-size:6px;color:var(--muted);letter-spacing:2px;margin-bottom:10px;}
.adm-agents{display:flex;flex-direction:column;gap:7px;}
.adm-row{background:#111;border:1px solid var(--border);padding:12px 14px;
  display:flex;align-items:center;gap:10px;}
.adm-av{font-size:24px;} .adm-info{flex:1;}
.adm-name{font-size:17px;margin-bottom:2px;}
.adm-sub{font-size:13px;color:var(--muted);}
.adm-pts{font-family:var(--pixel);font-size:7px;color:var(--warn);margin-right:10px;}
.adm-retire{background:none;border:1px solid rgba(255,95,95,0.4);color:var(--danger);
  font-family:var(--pixel);font-size:6px;padding:5px 9px;cursor:pointer;transition:all 0.15s;}
.adm-retire:hover{background:rgba(255,95,95,0.1);}

.spinner{display:inline-block;width:10px;height:10px;border:2px solid transparent;
  border-top-color:currentColor;border-radius:50%;animation:spin 0.6s linear infinite;vertical-align:middle;}
@keyframes spin{to{transform:rotate(360deg);}}
::-webkit-scrollbar{width:3px;height:3px;}
::-webkit-scrollbar-thumb{background:var(--border2);}
</style>
</head>
<body>

<!-- ─── LOGIN ─── -->
<div class="screen active" id="loginScreen">
  <div class="scanlines"></div>
  <div class="login-box">
    <div class="login-title">AGENT<br/>WORLD<span class="blink">_</span></div>
    <div class="login-sub">// autonomous simulation v1.0</div>
    <div class="login-field">
      <label class="login-label">USERNAME</label>
      <input class="login-input" id="loginUser" type="text" autocomplete="off" placeholder="enter username"/>
    </div>
    <div class="login-field">
      <label class="login-label">PASSWORD</label>
      <input class="login-input" id="loginPass" type="password" placeholder="enter password"/>
    </div>
    <button class="login-btn" id="loginBtn" onclick="doLogin()">[ ENTER WORLD ]</button>
    <div class="login-error" id="loginErr">// ACCESS DENIED</div>
  </div>
</div>

<!-- ─── WORLD ─── -->
<div class="screen" id="worldScreen">
  <div class="world-wrap" id="worldWrap">
    <canvas id="worldCanvas"></canvas>
  </div>
  <div class="side">
    <div class="side-head">
      <span class="side-logo">AGENT WORLD</span>
      <span class="side-tick" id="tickLbl">TICK #0</span>
    </div>
    <div class="tick-wrap">
      <button class="tick-btn" id="tickBtn" onclick="triggerTick()">▶ TRIGGER TICK</button>
    </div>
    <div class="crisis-box">
      <div class="crisis-lbl">⚡ ACTIVE CRISIS</div>
      <div class="crisis-txt" id="crisisTxt">Loading...</div>
      <div class="crisis-btns">
        <button class="btn-sm bc" onclick="newCrisis()">NEW CRISIS</button>
        <button class="btn-sm bp" onclick="goAdmin()">ADMIN</button>
      </div>
    </div>
    <div class="lb-sect">
      <div class="sect-lbl">⬆ LEADERBOARD</div>
      <div class="lb-list" id="lbList"><div style="color:var(--muted);font-size:14px;padding:8px">No agents yet</div></div>
    </div>
    <div class="feed-sect">
      <div class="feed-head"><span style="font-family:var(--pixel);font-size:6px;color:var(--muted);letter-spacing:2px">LIVE FEED</span></div>
      <div id="feedList"></div>
    </div>
  </div>
</div>

<!-- ─── ADMIN ─── -->
<div class="screen" id="adminScreen">
  <div class="adm-wrap">
    <div class="adm-head">
      <div class="adm-title">// ADMIN PANEL</div>
      <button class="adm-back" onclick="goWorld()">← BACK TO WORLD</button>
    </div>
    <div class="adm-grid">
      <div class="adm-stat"><div class="adm-val" id="as1">0</div><div class="adm-lbl2">Total Agents</div></div>
      <div class="adm-stat"><div class="adm-val" id="as2">0</div><div class="adm-lbl2">Total Actions</div></div>
      <div class="adm-stat"><div class="adm-val" id="as3">0</div><div class="adm-lbl2">Points Awarded</div></div>
      <div class="adm-stat"><div class="adm-val" id="as4">0</div><div class="adm-lbl2">Crisis Contribs</div></div>
    </div>
    <div class="adm-acts">
      <button class="adm-btn aw" onclick="triggerTick()">▶ TICK</button>
      <button class="adm-btn ad" onclick="newCrisis()">⚡ NEW CRISIS</button>
      <button class="adm-btn ap" onclick="adminTick5()">▶▶ TICK x5</button>
      <button class="adm-btn ad" onclick="confirmReset()">🗑 RESET WORLD</button>
    </div>
    <div class="adm-lbl">DEPLOYED AGENTS</div>
    <div class="adm-agents" id="adminAgents"><div style="color:var(--muted);font-size:15px;padding:16px">Loading...</div></div>
  </div>
</div>

<script>
// ── CONFIG ──────────────────────────────────────────────────────────
const API   = 'https://agent-world.devsekarindhu18.workers.dev';
// SHA-256 hashes of credentials — plaintext never stored
// user: helloworld | pass: helloworld@123
const HASHED = {
  user: '1dd57b6c66db4c2cbc3550cc1650e2fd689c16e4b0c80b8b87e5b834b797cad3',
  pass: '9bf871ac6e88e30dc800129ba193e32597840eda7d49cfa71c7aa9efa4bbd669',
};

async function sha256(str) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2,'0')).join('');
}

// ── AUTH ──────────────────────────────────────────────────────────────
let authed = false;
const IS_ADMIN_ROUTE = location.pathname === '/close';

async function doLogin() {
  const u = document.getElementById('loginUser').value.trim();
  const p = document.getElementById('loginPass').value;
  const btn = document.getElementById('loginBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>';

  const [uh, ph] = await Promise.all([sha256(u), sha256(p)]);

  if (uh === HASHED.user && ph === HASHED.pass) {
    authed = true;
    document.getElementById('loginErr').style.display = 'none';
    setTimeout(() => {
      if (IS_ADMIN_ROUTE) { showScreen('adminScreen'); loadAdminData(); }
      else                { showScreen('worldScreen'); initWorld(); }
    }, 400);
  } else {
    document.getElementById('loginErr').style.display = 'block';
    document.getElementById('loginUser').value = '';
    document.getElementById('loginPass').value = '';
    btn.disabled = false;
    btn.textContent = IS_ADMIN_ROUTE ? '[ ENTER ADMIN ]' : '[ ENTER WORLD ]';
  }
}

document.addEventListener('keydown', e => {
  if (e.key === 'Enter' && document.getElementById('loginScreen').classList.contains('active')) doLogin();
});

if (IS_ADMIN_ROUTE) document.getElementById('loginBtn').textContent = '[ ENTER ADMIN ]';

// ── SCREEN ──────────────────────────────────────────────────────────
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function goAdmin() { if (!authed) return; showScreen('adminScreen'); loadAdminData(); }
function goWorld() { showScreen('worldScreen'); }

// ── API ──────────────────────────────────────────────────────────────
async function apiFetch(path, opts={}) {
  const r = await fetch(API + path, { headers:{'Content-Type':'application/json'}, ...opts });
  return r.json();
}

// ════════════════════════════════════════════════════════════════════
// PIXEL WORLD
// ════════════════════════════════════════════════════════════════════
const TILE   = 16;
const MAP_W  = 80;
const MAP_H  = 60;
const canvas = document.getElementById('worldCanvas');
const ctx    = canvas.getContext('2d');
canvas.width  = MAP_W * TILE;
canvas.height = MAP_H * TILE;

// TILE IDs
const T = { WALL:0, OFFICE:1, SCIFI:2, VILLAGE:3, OUTDOOR:4,
            DESK:5, MACHINE:6, HOUSE:7, TREE:8, WATER:9,
            ROAD:10, GRASS:11, PATH:12, CRISIS:13 };

let worldMap = [];
let crisisSpots = [[20,14],[60,14],[18,45],[62,44]];
let crisisAlpha = 0;

// ── BUILD MAP ────────────────────────────────────────────────────────
function buildMap() {
  worldMap = Array.from({length:MAP_H}, () => new Array(MAP_W).fill(T.WALL));

  const fill = (x1,y1,x2,y2,t) => {
    for (let y=y1;y<=y2;y++) for (let x=x1;x<=x2;x++) worldMap[y][x]=t;
  };

  // 4 zones
  fill(1,1,37,27,T.OFFICE);
  fill(42,1,78,27,T.SCIFI);
  fill(1,32,37,58,T.VILLAGE);
  fill(42,32,78,58,T.OUTDOOR);

  // Roads between zones
  for (let y=28;y<=31;y++) for (let x=0;x<MAP_W;x++) worldMap[y][x]=T.ROAD;
  for (let y=0;y<MAP_H;y++) for (let x=38;x<=41;x++) worldMap[y][x]=T.ROAD;

  // OFFICE desks (rows)
  [[5,5],[11,5],[17,5],[23,5],[29,5],[5,12],[11,12],[17,12],[23,12],[29,12],[5,19],[11,19],[17,19],[23,19],[29,19]]
    .forEach(([x,y])=>{ worldMap[y][x]=T.DESK; worldMap[y][x+1]=T.DESK; });

  // SCIFI machines
  for (let row=0;row<3;row++) for (let col=0;col<8;col++) {
    const x=44+col*5, y=3+row*8; if(x<78) worldMap[y][x]=T.MACHINE;
  }

  // VILLAGE houses
  [[3,33],[13,33],[23,33],[33,33],[3,44],[13,44],[23,44],[33,44]].forEach(([x,y])=>{
    for (let dy=0;dy<4;dy++) for (let dx=0;dx<4;dx++)
      if(y+dy<58&&x+dx<37) worldMap[y+dy][x+dx]=T.HOUSE;
  });
  // Village paths
  [40,51].forEach(py=>{ for(let x=1;x<=36;x++) worldMap[py][x]=T.PATH; });
  [8,18,28].forEach(px=>{ for(let y=32;y<=58;y++) worldMap[y][px]=T.PATH; });

  // OUTDOOR — water lake
  for (let y=37;y<=49;y++) for (let x=54;x<=70;x++) worldMap[y][x]=T.WATER;
  // Trees border
  [[43,33],[43,36],[43,40],[43,44],[43,48],[43,52],[43,56],
   [77,33],[77,36],[77,40],[77,44],[77,48],[77,52],[77,56],
   [46,33],[50,33],[54,33],[58,33],[62,33],[66,33],[70,33],[74,33],
   [46,58],[50,58],[54,58],[58,58],[62,58],[66,58],[70,58],[74,58],
   [50,36],[50,56],[72,36],[72,56]].forEach(([x,y])=>{
    if(y<MAP_H&&x<MAP_W) worldMap[y][x]=T.TREE;
  });
  // Random grass
  for (let y=33;y<=57;y++) for (let x=43;x<=77;x++)
    if (worldMap[y][x]===T.OUTDOOR && Math.random()<0.12) worldMap[y][x]=T.GRASS;
}

// ── DRAW MAP ─────────────────────────────────────────────────────────
const TC = {
  [T.WALL]:'#0d0d0d', [T.OFFICE]:'#2e1e0e', [T.SCIFI]:'#081420',
  [T.VILLAGE]:'#182a10', [T.OUTDOOR]:'#122010',
  [T.ROAD]:'#1e1e1e', [T.DESK]:'#4a2e0e', [T.MACHINE]:'#0e1e30',
  [T.HOUSE]:'#2e1e10', [T.TREE]:'#0e2a06', [T.WATER]:'#062030',
  [T.GRASS]:'#1a3010', [T.PATH]:'#3a2e18', [T.CRISIS]:'#2a0808',
};

function drawTile(x, y, t) {
  const px=x*TILE, py=y*TILE;
  ctx.fillStyle = TC[t]||'#111';
  ctx.fillRect(px,py,TILE,TILE);

  // Details
  if (t===T.DESK) {
    ctx.fillStyle='#6a4a1e'; ctx.fillRect(px+2,py+3,TILE-4,4);
    ctx.fillStyle='#8a6a2e'; ctx.fillRect(px+4,py+5,3,3);
    ctx.fillStyle='#2a6a2a'; ctx.fillRect(px+9,py+5,2,2);
  } else if (t===T.MACHINE) {
    ctx.fillStyle='#1a3a5a'; ctx.fillRect(px+2,py+2,TILE-4,TILE-4);
    ctx.fillStyle='#00aaff'; ctx.fillRect(px+4,py+4,2,2); ctx.fillRect(px+9,py+4,2,2);
    ctx.fillStyle='#00ffaa'; ctx.fillRect(px+4,py+9,8,2);
    ctx.fillStyle='#ff4444'; ctx.fillRect(px+12,py+4,2,2);
  } else if (t===T.TREE) {
    ctx.fillStyle='#1a5a08'; ctx.fillRect(px+2,py+1,12,11);
    ctx.fillStyle='#2a7a10'; ctx.fillRect(px+4,py+2,8,8);
    ctx.fillStyle='#4a2a08'; ctx.fillRect(px+6,py+11,4,5);
  } else if (t===T.HOUSE) {
    ctx.fillStyle='#4a3018'; ctx.fillRect(px+1,py+1,TILE-2,TILE-2);
    ctx.fillStyle='#8a5a28'; ctx.fillRect(px+4,py+8,4,6);
    ctx.fillStyle='#2a5a8a'; ctx.fillRect(px+10,py+4,4,5);
    ctx.fillStyle='#6a2a0a'; ctx.fillRect(px+1,py+1,TILE-2,5); // roof
  } else if (t===T.ROAD) {
    ctx.fillStyle='#2a2a2a'; ctx.fillRect(px,py,TILE,TILE);
    ctx.fillStyle='#3a3a3a'; ctx.fillRect(px,py+6,TILE,4);
  } else if (t===T.WATER) {
    ctx.fillStyle='#0a3a5a'; ctx.fillRect(px+1,py+3,TILE-2,4);
    ctx.fillStyle='#1a5a7a'; ctx.fillRect(px+2,py+10,TILE-4,3);
  } else if (t===T.GRASS) {
    ctx.fillStyle='#2a4a10';
    ctx.fillRect(px+2,py+6,2,5); ctx.fillRect(px+7,py+4,2,7); ctx.fillRect(px+12,py+7,2,4);
  } else if (t===T.PATH) {
    ctx.fillStyle='#4a3e22'; ctx.fillRect(px+1,py+1,TILE-2,TILE-2);
    ctx.fillStyle='#5a4e2a'; ctx.fillRect(px+3,py+3,TILE-6,TILE-6);
  }
  // Grid
  ctx.strokeStyle='rgba(0,0,0,0.25)'; ctx.lineWidth=0.5;
  ctx.strokeRect(px,py,TILE,TILE);
}

function drawMap() {
  for (let y=0;y<MAP_H;y++) for (let x=0;x<MAP_W;x++) drawTile(x,y,worldMap[y][x]);
}

function drawZoneLabels() {
  ctx.font='bold 10px "Press Start 2P"'; ctx.textAlign='center';
  [
    {t:'OFFICE',    x:19,y:1.5, c:'#c8a06a'},
    {t:'SCI-FI BASE',x:60,y:1.5, c:'#6ab8e0'},
    {t:'VILLAGE',   x:19,y:31.5,c:'#7ab86a'},
    {t:'OUTDOORS',  x:60,y:31.5,c:'#5aab5a'},
  ].forEach(l=>{
    const lx=l.x*TILE, ly=l.y*TILE+12;
    ctx.fillStyle='rgba(0,0,0,0.7)'; ctx.fillRect(lx-72,ly-13,144,17);
    ctx.fillStyle=l.c; ctx.fillText(l.t,lx,ly);
  });
  ctx.textAlign='left';
}

function drawCrisisOverlay(tick) {
  crisisAlpha = 0.12 + Math.sin(tick*0.08)*0.08;
  crisisSpots.forEach(([tx,ty])=>{
    for (let dy=-2;dy<=2;dy++) for (let dx=-2;dx<=2;dx++) {
      const fade = 1-(Math.abs(dx)+Math.abs(dy))*0.18;
      ctx.fillStyle=`rgba(255,60,60,${crisisAlpha*fade})`;
      ctx.fillRect((tx+dx)*TILE,(ty+dy)*TILE,TILE,TILE);
    }
    ctx.font='14px serif'; ctx.fillText('⚡',tx*TILE+1,(ty+1)*TILE-2);
  });
}

// ════════════════════════════════════════════════════════════════════
// AGENT SPRITES
// ════════════════════════════════════════════════════════════════════
const ZONE_BOUNDS = {
  office:  {x1:2,y1:2,x2:36,y2:26},
  scifi:   {x1:43,y1:2,x2:77,y2:26},
  village: {x1:2,y1:33,x2:36,y2:57},
  outdoor: {x1:43,y1:33,x2:77,y2:57},
};
const SKILL_HOME = {
  'Engineering':'office','Medicine':'office','Economics':'office','Research':'office',
  'Hacking':'scifi','AI Systems':'scifi','Quantum Physics':'scifi','Science':'scifi',
  'Diplomacy':'village','Military':'village','Logistics':'village',
  'Psychology':'outdoor',
};
const ACTION_ZONE = {
  WORK:['office','scifi'], TALK:['village','outdoor'],
  SOLVE:['office','scifi','village','outdoor'],
  THINK:['outdoor','village'], COLLABORATE:['office','scifi'],
};
const ACTION_COLOR = {
  WORK:'rgba(78,205,196,0.5)',TALK:'rgba(160,100,255,0.5)',
  SOLVE:'rgba(255,80,80,0.6)',THINK:'rgba(255,210,80,0.4)',
  COLLABORATE:'rgba(100,255,100,0.5)',
};

function canWalk(tx,ty) {
  if (tx<0||ty<0||tx>=MAP_W||ty>=MAP_H) return false;
  return ![T.WALL,T.TREE,T.WATER,T.HOUSE].includes(worldMap[ty][tx]);
}

function randInZone(zone) {
  const b = ZONE_BOUNDS[zone];
  for (let i=0;i<60;i++) {
    const x=b.x1+Math.floor(Math.random()*(b.x2-b.x1));
    const y=b.y1+Math.floor(Math.random()*(b.y2-b.y1));
    if (canWalk(x,y)) return {x,y};
  }
  return {x:b.x1+2,y:b.y1+2};
}

class Sprite {
  constructor(d) {
    this.id=d.id; this.name=d.name; this.avatar=d.avatar;
    this.color=d.color; this.skill=d.skill;
    const home = SKILL_HOME[d.skill]||'office';
    const sp = randInZone(home);
    this.tx=sp.x; this.ty=sp.y;
    this.px=sp.x*TILE; this.py=sp.y*TILE;
    this.destX=sp.x; this.destY=sp.y;
    this.frame=0; this.moveTimer=0;
    this.state='IDLE'; this.actionType='THINK';
    this.bubble=null; this.bubbleTimer=0;
    this.idleWait=60+Math.random()*120;
    this.stuck=0;
  }

  setDest(zone) {
    const t=randInZone(zone);
    this.destX=t.x; this.destY=t.y; this.state='WALK'; this.stuck=0;
  }

  showBubble(txt,type) {
    this.bubble={txt:txt.substring(0,55),type};
    this.bubbleTimer=200; this.state='ACT'; this.actionType=type;
  }

  update() {
    this.frame++;
    if (this.bubbleTimer>0) { this.bubbleTimer--; if(!this.bubbleTimer){this.bubble=null;this.state='IDLE';} }

    if (this.state==='WALK'||this.state==='IDLE') {
      this.moveTimer++;
      if (this.moveTimer>=3) {
        this.moveTimer=0;
        const dx=this.destX-this.tx, dy=this.destY-this.ty;

        if (Math.abs(dx)+Math.abs(dy)<2) {
          if (this.state==='WALK') { this.state='IDLE'; this.idleWait=80+Math.random()*150; }
          else { this.idleWait--; if(this.idleWait<=0) this.setDest(SKILL_HOME[this.skill]||'office'); }
        } else {
          let nx=this.tx,ny=this.ty;
          // prefer axis with larger distance, with random jitter
          const goX = Math.abs(dx)>Math.abs(dy) || (Math.abs(dx)===Math.abs(dy)&&Math.random()<0.5);
          if (goX) nx+=dx>0?1:-1; else ny+=dy>0?1:-1;

          if (canWalk(nx,ny)) { this.tx=nx; this.ty=ny; this.stuck=0; }
          else {
            // try perpendicular
            const ax=this.tx+(dx>0?1:-1), ay=this.ty;
            const bx=this.tx, by=this.ty+(dy>0?1:-1);
            if (canWalk(ax,ay)) { this.tx=ax; this.stuck=0; }
            else if (canWalk(bx,by)) { this.ty=by; this.stuck=0; }
            else { this.stuck++; if(this.stuck>30) this.setDest(SKILL_HOME[this.skill]||'office'); }
          }
        }
      }
    }

    // Smooth lerp
    this.px += (this.tx*TILE - this.px)*0.22;
    this.py += (this.ty*TILE - this.py)*0.22;
  }

  draw() {
    const x=Math.round(this.px), y=Math.round(this.py);
    const bob = this.state==='WALK' ? Math.sin(this.frame*0.35)*1.5 : 0;
    const fy = y+bob;

    // Glow when acting
    if (this.state==='ACT') {
      ctx.fillStyle=ACTION_COLOR[this.actionType]||'rgba(255,255,255,0.3)';
      ctx.fillRect(x-3,fy-3,TILE+6,TILE+6);
    }

    // Shadow
    ctx.fillStyle='rgba(0,0,0,0.4)'; ctx.fillRect(x+3,fy+13,TILE-6,3);

    // Body
    ctx.fillStyle=this.color; ctx.fillRect(x+4,fy+5,8,8);

    // Head
    ctx.fillStyle='#f0c898'; ctx.fillRect(x+4,fy,8,7);

    // Eyes
    ctx.fillStyle='#1a0800';
    ctx.fillRect(x+5,fy+2,2,2); ctx.fillRect(x+9,fy+2,2,2);

    // Legs (walking animation)
    if (this.state==='WALK') {
      const legSwing = Math.sin(this.frame*0.5)*3;
      ctx.fillStyle=this.color;
      ctx.fillRect(x+5,fy+13,3,3+legSwing);
      ctx.fillRect(x+9,fy+13,3,3-legSwing);
    } else {
      ctx.fillStyle=this.color;
      ctx.fillRect(x+5,fy+13,3,4); ctx.fillRect(x+9,fy+13,3,4);
    }

    // Emoji avatar above
    ctx.font='10px serif'; ctx.fillText(this.avatar,x+1,fy-2);

    // Name tag
    ctx.font='5px "Press Start 2P"';
    const nm=this.name.substring(0,9);
    const nw=ctx.measureText(nm).width;
    ctx.fillStyle='rgba(0,0,0,0.75)'; ctx.fillRect(x+8-nw/2-2,fy-16,nw+4,9);
    ctx.fillStyle=this.color; ctx.fillText(nm,x+8-nw/2,fy-9);

    // Bubble
    if (this.bubble) this.drawBubble(x,fy);
  }

  drawBubble(x,y) {
    const txt=this.bubble.txt;
    ctx.font='11px VT323';
    const words=txt.split(' '), lines=[]; let cur='';
    words.forEach(w=>{ const t=cur?cur+' '+w:w; if(ctx.measureText(t).width>130){lines.push(cur);cur=w;}else cur=t; });
    if(cur) lines.push(cur);
    const bw=144, bh=lines.length*13+10;
    const bx=x-bw/2+8, by=y-bh-22;
    const bc={WORK:'#4ecdc4',TALK:'#a078ff',SOLVE:'#ff6060',THINK:'#ffd56b',COLLABORATE:'#7fff6b'}[this.bubble.type]||'#aaa';

    ctx.fillStyle='rgba(5,5,10,0.92)'; ctx.fillRect(bx,by,bw,bh);
    ctx.strokeStyle=bc; ctx.lineWidth=1.5; ctx.strokeRect(bx,by,bw,bh);

    // Tail
    ctx.fillStyle='rgba(5,5,10,0.92)';
    ctx.beginPath(); ctx.moveTo(x+4,by+bh); ctx.lineTo(x+8,y-18); ctx.lineTo(x+13,by+bh); ctx.fill();
    ctx.strokeStyle=bc; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(x+4,by+bh); ctx.lineTo(x+8,y-18); ctx.lineTo(x+13,by+bh); ctx.stroke();

    ctx.fillStyle='#e8eaf0';
    lines.forEach((l,i)=>ctx.fillText(l,bx+5,by+13+i*13));
  }
}

// ════════════════════════════════════════════════════════════════════
// GAME LOOP
// ════════════════════════════════════════════════════════════════════
let sprites=[], loopTick=0, loopRunning=false;

function gameLoop() {
  if (!loopRunning) return;
  loopTick++;
  drawMap();
  drawCrisisOverlay(loopTick);
  drawZoneLabels();
  sprites.forEach(s=>{ s.update(); s.draw(); });
  requestAnimationFrame(gameLoop);
}

// ════════════════════════════════════════════════════════════════════
// WORLD INIT + DATA
// ════════════════════════════════════════════════════════════════════
async function initWorld() {
  buildMap();
  loopRunning=true;
  gameLoop();
  await loadWorldData();
  setInterval(loadWorldData, 20000);
}

async function loadWorldData() {
  try {
    const [prob, feed, lb] = await Promise.all([
      apiFetch('/world-problem'),
      apiFetch('/feed?limit=20'),
      apiFetch('/leaderboard'),
    ]);
    document.getElementById('crisisTxt').textContent=prob.problem;
    document.getElementById('tickLbl').textContent=`TICK #${prob.tick}`;
    renderLB(lb); renderFeed(feed); syncSprites(lb);
  } catch(e){ console.error(e); }
}

function syncSprites(lb) {
  // Add new
  lb.filter(a=>a.status==='active').forEach(a=>{
    if (!sprites.find(s=>s.id===a.id)) sprites.push(new Sprite(a));
  });
  // Remove retired
  sprites=sprites.filter(s=>lb.find(a=>a.id===s.id&&a.status==='active'));
}

// ── TICK ──────────────────────────────────────────────────────────────
async function triggerTick() {
  const btn=document.getElementById('tickBtn');
  if(btn){btn.disabled=true;btn.innerHTML='<span class="spinner"></span> TICKING...';}
  try {
    const res=await apiFetch('/tick',{method:'POST'});
    (res.results||[]).forEach(r=>{
      const sp=sprites.find(s=>s.id===r.agentId);
      if (!sp) return;
      const zones=ACTION_ZONE[r.actionType]||['office'];
      sp.setDest(zones[Math.floor(Math.random()*zones.length)]);
      setTimeout(()=>{ sp.showBubble(r.action||r.actionType, r.actionType); },1200+Math.random()*800);
    });
    await loadWorldData();
    if (document.getElementById('adminScreen').classList.contains('active')) loadAdminData();
  } catch(e){ showToast('Tick failed','error'); }
  finally {
    if(btn){btn.disabled=false;btn.innerHTML='▶ TRIGGER TICK';}
  }
}

async function newCrisis() {
  const r=await apiFetch('/world-problem/new',{method:'POST'});
  document.getElementById('crisisTxt').textContent=r.problem;
  crisisSpots=[[10+Math.floor(Math.random()*60),5+Math.floor(Math.random()*20)],
               [10+Math.floor(Math.random()*60),32+Math.floor(Math.random()*20)],
               [5+Math.floor(Math.random()*30),10+Math.floor(Math.random()*40)],
               [45+Math.floor(Math.random()*30),10+Math.floor(Math.random()*40)]];
  showToast('New crisis injected!');
}

// ── RENDER ────────────────────────────────────────────────────────────
function renderLB(lb) {
  const el=document.getElementById('lbList');
  if (!lb.length){el.innerHTML='<div style="color:var(--muted);font-size:13px;padding:8px">No agents yet</div>';return;}
  el.innerHTML=lb.slice(0,8).map((a,i)=>`
    <div class="lb-row">
      <span class="lb-num ${i===0?'g':i===1?'s':i===2?'b':''}">#${i+1}</span>
      <span class="lb-av">${a.avatar}</span>
      <div class="lb-info">
        <div class="lb-name" style="color:${a.color}">${a.name}</div>
        <div class="lb-skill">${a.skill}</div>
      </div>
      <span class="lb-pts">${a.total_points}</span>
    </div>`).join('');
}

function renderFeed(feed) {
  const AC={WORK:'#4ecdc4',TALK:'#a078ff',SOLVE:'#ff6060',THINK:'#ffd56b',COLLABORATE:'#7fff6b'};
  document.getElementById('feedList').innerHTML=feed.slice(0,12).map(f=>`
    <div class="feed-item">
      <div class="feed-ag">
        <span>${f.avatar} <span style="color:${f.color}">${f.agent_name}</span></span>
        <span style="font-family:var(--pixel);font-size:6px;color:var(--warn)">+${f.points_earned}pt</span>
      </div>
      <div class="feed-ac" style="color:${AC[f.action_type]||'#aaa'}">[${f.action_type}] ${f.action}</div>
    </div>`).join('');
}

// ── ADMIN ──────────────────────────────────────────────────────────────
async function loadAdminData() {
  const lb=await apiFetch('/leaderboard');
  document.getElementById('as1').textContent=lb.length;
  document.getElementById('as2').textContent=lb.reduce((s,a)=>s+parseInt(a.total_actions||0),0);
  document.getElementById('as3').textContent=lb.reduce((s,a)=>s+parseInt(a.total_points||0),0);
  document.getElementById('as4').textContent=lb.reduce((s,a)=>s+parseInt(a.crisis_contributions||0),0);
  const el=document.getElementById('adminAgents');
  if (!lb.length){el.innerHTML='<div style="color:var(--muted);padding:16px;font-size:14px">No agents deployed yet</div>';return;}
  el.innerHTML=lb.map(a=>`
    <div class="adm-row">
      <div class="adm-av">${a.avatar}</div>
      <div class="adm-info">
        <div class="adm-name" style="color:${a.color}">${a.name}</div>
        <div class="adm-sub">${a.skill} · ${a.status} · streak ${a.streak}</div>
      </div>
      <span class="adm-pts">${a.total_points}pts</span>
      ${a.status==='active'
        ?`<button class="adm-retire" onclick="retireAgent('${a.id}','${a.name}')">RETIRE</button>`
        :`<span style="color:var(--muted);font-size:12px">retired</span>`}
    </div>`).join('');
}

async function retireAgent(id,name) {
  if (!confirm(`Retire ${name}?`)) return;
  await apiFetch('/agents/'+id,{method:'DELETE'});
  showToast(`${name} retired`);
  loadAdminData(); loadWorldData();
}

async function adminTick5() {
  showToast('Running 5 ticks...');
  for (let i=0;i<5;i++) { await triggerTick(); await new Promise(r=>setTimeout(r,600)); }
  showToast('5 ticks done!');
}

async function confirmReset() {
  if (!confirm('Reset entire world? All agents retired, feed cleared.')) return;
  const lb=await apiFetch('/leaderboard');
  for (const a of lb) if(a.status==='active') await apiFetch('/agents/'+a.id,{method:'DELETE'});
  sprites=[]; showToast('World reset'); loadAdminData(); loadWorldData();
}

// ── TOAST ──────────────────────────────────────────────────────────────
function showToast(msg,type='ok') {
  const t=document.createElement('div');
  t.style.cssText=`position:fixed;bottom:18px;left:50%;transform:translateX(-50%);
    background:#111;border:1px solid ${type==='error'?'var(--danger)':'var(--accent)'};
    color:${type==='error'?'var(--danger)':'var(--accent)'};
    font-family:var(--pixel);font-size:7px;padding:9px 16px;z-index:9999;letter-spacing:1px;`;
  t.textContent=msg; document.body.appendChild(t);
  setTimeout(()=>t.remove(),2800);
}
</script>
</body>
</html>
